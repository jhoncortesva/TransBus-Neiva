{
  "expo": {
    "name": "Coomotor",
    "slug": "coomotor-app",
    "version": "1.0.0",
    "sdkVersion": "52.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#1565C0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "config": {
        "googleMapsApiKey": "AIzaSyAd8umMVzvZRTqNuQdmT9vVd7qH7u5a-i0"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Coomotor necesita acceso a tu ubicación para mostrarte en el mapa.",
        "NSLocationAlwaysUsageDescription": "Coomotor necesita acceso a tu ubicación para mostrarte en el mapa."
      }
    },
    "icon": "./assets/icon.png",
    "android": {
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1565C0"
      },
      "package": "com.coomotor.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAd8umMVzvZRTqNuQdmT9vVd7qH7u5a-i0"
        }
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "usesCleartextTraffic": true
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1565C0"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Coomotor necesita acceso a tu ubicación para mostrarte en el mapa."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1565C0",
          "androidMode": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Coomotor necesita acceso a tu galería para cambiar la foto de perfil."
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "web": {},
    "extra": {
      "eas": {
        "projectId": "74b5fe2e-5f86-4366-9774-98e9dae9e51d"
      }
    },
    "owner": "jhoncitito"
  }
}
